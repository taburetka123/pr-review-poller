#!/usr/bin/env bash
# Unattended PR auto-review. Subcommands: status | start | stop | run | logs | config | help.
# Invoked by launchd as `pr-review-poller run` every N seconds.
set -euo pipefail

CONFIG_FILE="${PR_REVIEW_POLLER_CONFIG:-$HOME/.config/pr-review-poller/config.env}"
PLIST_DST="$HOME/Library/LaunchAgents/com.kezoo.pr-review-poller.plist"
LABEL="com.kezoo.pr-review-poller"
LOCK_FILE="$HOME/.local/state/pr-review-poller.lock"
LAST_RUN_FILE="$HOME/.local/state/pr-review-poller/last-run.epoch"
STDOUT_LOG="$HOME/worktrees/.pr-review-poller-stdout.log"
STDERR_LOG="$HOME/worktrees/.pr-review-poller-stderr.log"
FINDINGS_DIR="$HOME/worktrees/.pr-review-findings"
CLAUDE="/Users/kezoo/.local/bin/claude"

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
  MIN_COMMIT_AGE="${MIN_COMMIT_AGE:-10m}"
  REVIEW_FREQUENCY="${REVIEW_FREQUENCY:-2h}"
}

# Pretty-print whichever scheduling key the plist uses. StartCalendarInterval
# catches up on wake (one coalesced run); StartInterval does not.
plist_schedule() {
  local plist="$1"
  local interval cal
  if interval=$(plutil -extract StartInterval raw "$plist" 2>/dev/null); then
    echo "every ${interval}s (StartInterval — no catch-up after sleep)"
    return
  fi
  if cal=$(plutil -extract StartCalendarInterval json -o - "$plist" 2>/dev/null); then
    local minute hour
    minute=$(echo "$cal" | jq -r '.Minute // "*"' 2>/dev/null)
    hour=$(echo "$cal" | jq -r '.Hour // "*"' 2>/dev/null)
    echo "calendar: hour=$hour minute=$minute (catches up on wake)"
    return
  fi
  echo "unknown (no StartInterval or StartCalendarInterval)"
}

cmd_help() {
  cat <<EOF
pr-review-poller — unattended PR auto-review

Usage:
  pr-review-poller [status]          Show timer state, config, last run
  pr-review-poller start             Load the launchd job (begin polling)
  pr-review-poller start [--post] [--min-commit-age DUR] [--frequency DUR]
                                     Start with flags baked into the plist's
                                     job args so every tick uses them
  pr-review-poller stop              Unload the launchd job (pause polling)
  pr-review-poller run [--head]      Run one review cycle now
                                     --head opens an iTerm2 tab (debug)
  pr-review-poller run --min-commit-age DUR
                                     Override the commit-age gate for this run
  pr-review-poller run --frequency DUR
                                     Override the run-frequency gate (min gap
                                     between launchd ticks that do work)
  pr-review-poller run --force       Bypass the frequency gate for this run
  pr-review-poller run --post        Allow posting for this run. Default is
                                     no-post: POST decisions become HOLD;
                                     APPROVE still approves
  pr-review-poller logs [-n N]       Tail the stdout log (follow mode)
  pr-review-poller findings          List recent PR-findings logs (mtime sort)
  pr-review-poller findings <pr>     Print findings log for a PR. <pr> is a
                                     full URL (https://github.com/o/r/pull/N)
                                     or a bare number (must be unique across
                                     repos)
  pr-review-poller clear-hold <pr>   Remove a PR's held-ledger entry so the
                                     next tick re-reviews it. <pr> is a URL
                                     or bare number
  pr-review-poller config            Print current config
  pr-review-poller help              This help

Config:    $CONFIG_FILE
Plist:     $PLIST_DST
Logs:      $STDOUT_LOG
           $STDERR_LOG
Findings:  $FINDINGS_DIR/<owner>/<repo>/<number>.log
See: \$HOME/projects/personal/pr-review-poller/README.md
EOF
}

cmd_status() {
  load_config
  echo "=== pr-review-poller status ==="

  if [[ -f "$PLIST_DST" ]]; then
    SCHEDULE=$(plist_schedule "$PLIST_DST")
    JOB_ARGS=$(plutil -extract ProgramArguments json -o - "$PLIST_DST" 2>/dev/null | \
      jq -r '.[1:] | join(" ")' 2>/dev/null || echo "run")
    echo "plist:            $PLIST_DST"
    echo "  schedule:       $SCHEDULE"
    echo "  job args:       $JOB_ARGS"
  else
    echo "plist:            MISSING — run install.sh to create"
  fi

  if launchctl list | awk '{print $3}' | grep -qx "$LABEL"; then
    INFO=$(launchctl print "gui/$(id -u)/$LABEL" 2>&1)
    STATE=$(echo "$INFO" | awk -F'= ' '/^\tstate / {print $2; exit}')
    LAST_EXIT=$(echo "$INFO" | awk -F'= ' '/^\tlast exit code / {print $2; exit}')
    echo "launchd:          loaded (state: ${STATE:-?}, last exit: ${LAST_EXIT:-?})"
  else
    echo "launchd:          not loaded (run 'pr-review-poller start')"
  fi

  if [[ -f "$LOCK_FILE" ]]; then
    HOLDER_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [[ -n "$HOLDER_PID" ]] && kill -0 "$HOLDER_PID" 2>/dev/null; then
      echo "lock:             held by pid $HOLDER_PID (run in progress)"
    else
      echo "lock:             stale (pid ${HOLDER_PID:-?} no longer running)"
    fi
  else
    echo "lock:             free"
  fi

  echo "config:           $CONFIG_FILE"
  echo "  MIN_COMMIT_AGE:   $MIN_COMMIT_AGE"
  echo "  REVIEW_FREQUENCY: $REVIEW_FREQUENCY"

  if [[ -f "$LAST_RUN_FILE" ]]; then
    LAST_EPOCH=$(cat "$LAST_RUN_FILE" 2>/dev/null || echo 0)
    NOW_EPOCH=$(date +%s)
    ELAPSED=$(( NOW_EPOCH - LAST_EPOCH ))
    LAST_HUMAN=$(date -r "$LAST_EPOCH" -Iseconds 2>/dev/null || echo "?")
    echo "last run:         $LAST_HUMAN (${ELAPSED}s ago)"
  else
    echo "last run:         never (or last-run file missing)"
  fi

  if [[ -f "$STDOUT_LOG" ]]; then
    LAST=$(grep -E '^\[.*\] (poll start|poll done|previous run)' "$STDOUT_LOG" 2>/dev/null | tail -1 || echo "")
    [[ -n "$LAST" ]] && echo "last log entry:   $LAST"
  fi

  HELD="$HOME/.local/state/pr-review-poller/held.json"
  if [[ -f "$HELD" ]] && [[ $(jq 'length' "$HELD" 2>/dev/null || echo 0) -gt 0 ]]; then
    echo
    echo "held (waiting for human review):"
    jq -r 'to_entries[] | "  \(.key)\n    commit \(.value.commit[:7]), held \(.value.held_at)\n    \(.value.reason)\n    \(.value.pr_url)"' "$HELD"
  fi
}

cmd_start() {
  if [[ ! -f "$PLIST_DST" ]]; then
    echo "plist missing at $PLIST_DST — run install.sh first" >&2
    exit 1
  fi

  # Flags here rewrite the plist's ProgramArguments so every launchd tick runs
  # `pr-review-poller run <flags>`. Without flags, the existing plist is left
  # alone (so `start` after a prior `start --post` preserves posting mode).
  local POST_FLAG=0 MIN_AGE_FLAG="" FREQ_FLAG="" had_flag=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --post) POST_FLAG=1; had_flag=1; shift ;;
      --min-commit-age) MIN_AGE_FLAG="$2"; had_flag=1; shift 2 ;;
      --frequency) FREQ_FLAG="$2"; had_flag=1; shift 2 ;;
      *) echo "unknown flag: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$had_flag" == "1" ]]; then
    local args_json="[\"$HOME/.local/bin/pr-review-poller\",\"run\""
    [[ -n "$MIN_AGE_FLAG" ]] && args_json="$args_json,\"--min-commit-age\",\"$MIN_AGE_FLAG\""
    [[ -n "$FREQ_FLAG" ]]    && args_json="$args_json,\"--frequency\",\"$FREQ_FLAG\""
    [[ "$POST_FLAG" == "1" ]] && args_json="$args_json,\"--post\""
    args_json="$args_json]"
    plutil -replace ProgramArguments -json "$args_json" "$PLIST_DST"
  fi

  launchctl unload "$PLIST_DST" 2>/dev/null || true
  launchctl load "$PLIST_DST"
  SCHEDULE=$(plist_schedule "$PLIST_DST")
  JOB_ARGS=$(plutil -extract ProgramArguments json -o - "$PLIST_DST" 2>/dev/null | \
    jq -r '.[1:] | join(" ")' 2>/dev/null || echo "run")
  echo "started (schedule: $SCHEDULE, job args: $JOB_ARGS)."
}

cmd_stop() {
  launchctl unload "$PLIST_DST" 2>/dev/null || true
  echo "stopped"
}

duration_to_seconds() {
  case "$1" in
    0)  echo 0 ;;
    *m) echo $(( ${1%m} * 60 )) ;;
    *h) echo $(( ${1%h} * 3600 )) ;;
    *)  return 1 ;;
  esac
}

# Phase 1 discovery + filtering. Same logic as ~/.claude/skills/kezoo-review-prs/SKILL.md
# Phase 1, pulled into bash so empty/all-skipped ticks don't burn Claude tokens.
# Writes surviving PR URLs into the FILTER_SURVIVORS array (caller reads it).
# Prints "  skip #N: <reason>" log lines to stdout so the poller log captures them.
FILTER_SURVIVORS=()
filter_prs() {
  FILTER_SURVIVORS=()
  local me="aleksandr-beliakov-rs"
  local ledger="$HOME/.local/state/pr-review-poller/held.json"
  local now_epoch; now_epoch=$(date +%s)
  local min_seconds; min_seconds=$(duration_to_seconds "$MIN_COMMIT_AGE") || {
    echo "invalid --min-commit-age: $MIN_COMMIT_AGE" >&2
    return 2
  }

  # Mirrors the team-members list in ~/.claude/skills/kezoo-review-prs/SKILL.md.
  # Keep in sync when the skill's team changes.
  local team=(aleksandr-beliakov-rs artem-saidanov-rs dmitry-indikeev-rs alexandra-vorobyeva-rs maksym-drobotov-rs)

  local raw
  if ! raw=$(gh search prs --review-requested=@me --state=open --limit=50 \
      --json number,title,repository,author 2>&1); then
    echo "gh search failed: $raw" >&2
    return 1
  fi
  if [[ -z "$raw" || "$raw" == "[]" ]]; then
    return 0
  fi

  while IFS=$'\t' read -r owner repo number author; do
    [[ -z "$number" ]] && continue

    # 1. Team-author filter
    local in_team=0
    for t in "${team[@]}"; do
      [[ "$t" == "$author" ]] && { in_team=1; break; }
    done
    if [[ "$in_team" == "0" ]]; then
      echo "  skip #$number ($owner/$repo): author $author not on team"
      continue
    fi

    # 2. Repo-cloned check
    if [[ ! -d "$HOME/projects/work/$repo" ]]; then
      echo "  skip #$number ($owner/$repo): ~/projects/work/$repo not cloned"
      continue
    fi

    # 3. Single gh pr view for all remaining filters
    local info
    if ! info=$(gh pr view "$number" -R "$owner/$repo" --json reviews,commits 2>&1); then
      echo "  skip #$number ($owner/$repo): gh pr view failed ($info)"
      continue
    fi

    local head_oid committed_at
    head_oid=$(echo "$info" | jq -r '.commits[-1].oid' 2>/dev/null)
    committed_at=$(echo "$info" | jq -r '.commits[-1].committedDate' 2>/dev/null)
    if [[ -z "$head_oid" || "$head_oid" == "null" ]]; then
      echo "  skip #$number ($owner/$repo): could not parse HEAD commit"
      continue
    fi

    # 4. Commit-age gate
    local committed_epoch age
    # TZ=UTC is required: BSD `date -j -f` ignores the literal `Z` in the format
    # and parses the timestamp in $TZ, so without it the age is off by the
    # local offset (7h in +07) and every commit looks artificially old — the
    # gate never trips and too-young commits leak through to the auto-claim.
    committed_epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$committed_at" +%s 2>/dev/null)
    if [[ -z "$committed_epoch" ]]; then
      echo "  skip #$number ($owner/$repo): could not parse committedDate $committed_at"
      continue
    fi
    age=$(( now_epoch - committed_epoch ))
    if [[ "$age" -lt "$min_seconds" ]]; then
      echo "  skip #$number ($owner/$repo): newest commit is ${age}s old, below ${min_seconds}s threshold"
      continue
    fi

    # 5. Last-review-commit dedup
    local my_last_oid
    my_last_oid=$(echo "$info" | jq -r --arg me "$me" \
      '[.reviews[] | select(.author.login == $me)] | last | .commit.oid // empty' 2>/dev/null)
    if [[ -n "$my_last_oid" && "$my_last_oid" == "$head_oid" ]]; then
      echo "  skip #$number ($owner/$repo): already reviewed at HEAD ${head_oid:0:7}"
      continue
    fi

    # 6. Already-approved-by-anyone skip
    local approved
    approved=$(echo "$info" | jq '[.reviews | group_by(.author.login)[] | max_by(.submittedAt) | select(.state == "APPROVED")] | length > 0' 2>/dev/null)
    if [[ "$approved" == "true" ]]; then
      echo "  skip #$number ($owner/$repo): already approved by another reviewer"
      continue
    fi

    # 7. Held-ledger skip. Two flavours of entry:
    #   - real HOLD written by the skill — "pending human review"
    #   - "[in-flight]" placeholder written by cmd_run before invoking claude
    #     so a mid-review crash (rate-limit, etc.) doesn't burn a retry next
    #     tick. User clears via `pr-review-poller clear-hold <pr>`.
    if [[ -f "$ledger" ]]; then
      local held_commit held_reason
      held_commit=$(jq -r --arg key "$owner/$repo#$number" '.[$key].commit // empty' "$ledger" 2>/dev/null)
      held_reason=$(jq -r --arg key "$owner/$repo#$number" '.[$key].reason // empty' "$ledger" 2>/dev/null)
      if [[ "$held_commit" == "$head_oid" ]]; then
        if [[ "$held_reason" == \[in-flight\]* ]]; then
          echo "  skip #$number ($owner/$repo): in-flight entry at HEAD ${head_oid:0:7} (clear-hold to retry)"
        else
          echo "  skip #$number ($owner/$repo): held at HEAD ${head_oid:0:7} pending human review"
        fi
        continue
      fi
    fi

    # Tab-separated tuple so cmd_run can pre-write in-flight ledger entries
    # before invoking claude (needs head_oid, not just URL).
    FILTER_SURVIVORS+=("$owner"$'\t'"$repo"$'\t'"$number"$'\t'"$head_oid"$'\t'"https://github.com/$owner/$repo/pull/$number")
  done < <(echo "$raw" | jq -r '.[] | [
      (.repository.nameWithOwner | split("/")[0]),
      (.repository.nameWithOwner | split("/")[1]),
      (.number | tostring),
      .author.login
    ] | @tsv')
}

cmd_run() {
  load_config
  MODE="headless"
  POST=0
  FORCE=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --head) MODE="head"; shift ;;
      --min-commit-age) MIN_COMMIT_AGE="$2"; shift 2 ;;
      --frequency) REVIEW_FREQUENCY="$2"; shift 2 ;;
      --post) POST=1; shift ;;
      --force) FORCE=1; shift ;;
      *) echo "unknown flag: $1" >&2; exit 2 ;;
    esac
  done

  SLASH="/kezoo-review-prs --auto --min-commit-age ${MIN_COMMIT_AGE}"
  [[ "$POST" == "1" ]] && SLASH="$SLASH --post"

  if [[ "$MODE" == "head" ]]; then
    osascript <<OSA
tell application "iTerm"
  activate
  tell current window
    create tab with default profile
    delay 0.6
    tell current session of current tab
      write text "$CLAUDE -p \"$SLASH\""
    end tell
  end tell
end tell
OSA
    exit 0
  fi

  # PID-file lock (macOS has no flock). Self-heals after crashes via kill -0.
  mkdir -p "$(dirname "$LOCK_FILE")"
  if [[ -f "$LOCK_FILE" ]]; then
    OLD_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [[ -n "$OLD_PID" ]] && kill -0 "$OLD_PID" 2>/dev/null; then
      echo "[$(date -Iseconds)] previous run still active (pid $OLD_PID), skipping"
      exit 0
    fi
  fi
  echo $$ > "$LOCK_FILE"
  trap 'rm -f "$LOCK_FILE"' EXIT

  # cd to a work repo so any gh subcommand that reads remotes (gh pr view) lines
  # up with the right repo. The active gh account is forced via GH_TOKEN below.
  WORK_CWD="${PR_REVIEW_POLLER_WORK_CWD:-$HOME/projects/work/otto-service-requests-service}"
  if ! cd "$WORK_CWD" 2>/dev/null; then
    echo "[$(date -Iseconds)] work cwd missing ($WORK_CWD), skipping tick"
    exit 0
  fi

  # gh's active account is global, not cwd-scoped — under launchd it resolves to
  # the personal account, so `--review-requested=@me` returns nothing. Pull the
  # work-account token from the keyring and export it for this run only.
  WORK_GH_USER="${PR_REVIEW_POLLER_GH_USER:-aleksandr-beliakov-rs}"
  if ! GH_TOKEN=$(gh auth token --user "$WORK_GH_USER" -h github.com 2>&1); then
    echo "[$(date -Iseconds)] could not get gh token for $WORK_GH_USER: $GH_TOKEN"
    exit 0
  fi
  export GH_TOKEN

  echo "[$(date -Iseconds)] poll start (min-commit-age=$MIN_COMMIT_AGE, frequency=$REVIEW_FREQUENCY, post=$POST, cwd=$WORK_CWD, gh_user=$WORK_GH_USER)"

  # Frequency gate: launchd fires hourly so a post-sleep wake catches up
  # immediately, but we only do real work once per REVIEW_FREQUENCY window.
  # Stamp on gate-pass (not on claude success) so a claude rate-limit doesn't
  # cause hourly retries — the in-flight ledger already protects per-PR.
  # --force (manual override) bypasses the gate.
  if [[ "$FORCE" != "1" ]]; then
    local freq_seconds; freq_seconds=$(duration_to_seconds "$REVIEW_FREQUENCY") || {
      echo "[$(date -Iseconds)] invalid REVIEW_FREQUENCY=$REVIEW_FREQUENCY, skipping tick" >&2
      exit 0
    }
    if [[ -f "$LAST_RUN_FILE" ]]; then
      local last_epoch elapsed
      last_epoch=$(cat "$LAST_RUN_FILE" 2>/dev/null || echo 0)
      elapsed=$(( $(date +%s) - last_epoch ))
      if [[ "$elapsed" -lt "$freq_seconds" ]]; then
        echo "[$(date -Iseconds)] frequency gate: ${elapsed}s since last run, below ${freq_seconds}s threshold ($REVIEW_FREQUENCY) — skipping tick (use --force to override)"
        exit 0
      fi
    fi
  fi
  mkdir -p "$(dirname "$LAST_RUN_FILE")"
  date +%s > "$LAST_RUN_FILE"

  # Phase 1 in bash: only invoke Claude when ≥1 PR survives all filters.
  # filter_prs populates FILTER_SURVIVORS and prints skip reasons to stdout.
  if ! filter_prs; then
    echo "[$(date -Iseconds)] filter failed, skipping tick"
    exit 0
  fi

  if [[ ${#FILTER_SURVIVORS[@]} -eq 0 ]]; then
    echo "[$(date -Iseconds)] no PRs survived filters, skipping claude invocation"
    echo "[$(date -Iseconds)] poll done"
    exit 0
  fi

  # Pre-write an "[in-flight]" ledger entry per survivor BEFORE invoking claude.
  # The skill's HOLD path overwrites with the real entry (same key); POST/APPROVE
  # deletes it on success. If claude crashes mid-review (rate limit, etc.) the
  # placeholder persists, so the next tick's filter step 7 skips this exact
  # (PR, commit) instead of burning another retry. User runs
  # `pr-review-poller clear-hold <pr>` to force a re-review.
  local LEDGER="$HOME/.local/state/pr-review-poller/held.json"
  mkdir -p "$(dirname "$LEDGER")"
  [[ -f "$LEDGER" ]] || echo '{}' > "$LEDGER"
  local _now; _now=$(date -Iseconds)
  local _pr_urls=()
  for survivor in "${FILTER_SURVIVORS[@]}"; do
    IFS=$'\t' read -r _o _r _n _head _url <<<"$survivor"
    _pr_urls+=("$_url")
    local _tmp; _tmp=$(mktemp)
    jq --arg key "$_o/$_r#$_n" \
       --arg commit "$_head" \
       --arg now "$_now" \
       --arg url "$_url" \
       '.[$key] = {commit: $commit, held_at: $now, reason: "[in-flight] auto-claimed before review", pr_url: $url}' \
       "$LEDGER" > "$_tmp" && mv "$_tmp" "$LEDGER"
  done

  # Effort: medium is plenty for rule-driven triage (blocker = clearly broken;
  # major conf 5 = high-confidence broken). Higher effort just means longer
  # wall-time per tick, raising the odds of sleeping mid-review. Model stays
  # at the binary default (Opus) — at ~3 reviews/day, cost isn't the lever.
  CLAUDE_FLAGS=(--effort medium)
  echo "[$(date -Iseconds)] invoking claude (${CLAUDE_FLAGS[*]}) with ${#_pr_urls[@]} PR(s): ${_pr_urls[*]}"
  # Disable -e around claude so rate-limit / non-zero exit becomes a logged
  # outcome instead of a silent script death (which would leave the next tick
  # to infer "no 'poll done' line ⇒ probably rate-limited"). Survivors keep
  # their [in-flight] ledger entries either way — that's what protects against
  # retry — but the log should say so out loud.
  local rc=0
  "$CLAUDE" "${CLAUDE_FLAGS[@]}" -p "$SLASH ${_pr_urls[*]}" || rc=$?
  if [[ $rc -ne 0 ]]; then
    echo "[$(date -Iseconds)] poll FAILED — claude exited rc=$rc; ${#_pr_urls[@]} PR(s) remain in-flight, no retry until new commits or 'pr-review-poller clear-hold'"
    exit "$rc"
  fi
  echo "[$(date -Iseconds)] poll done"
}

cmd_logs() {
  if [[ ! -f "$STDOUT_LOG" ]]; then
    echo "no log yet at $STDOUT_LOG" >&2
    exit 1
  fi
  exec tail -F "$@" "$STDOUT_LOG"
}

cmd_config() {
  load_config
  if [[ -f "$CONFIG_FILE" ]]; then
    echo "# $CONFIG_FILE"
    cat "$CONFIG_FILE"
  else
    echo "no config file at $CONFIG_FILE (run install.sh)" >&2
    exit 1
  fi
}

# Locate or list the per-PR findings logs written by kezoo-review-prs.
# Layout: $FINDINGS_DIR/<owner>/<repo>/<number>.log
cmd_findings() {
  if [[ ! -d "$FINDINGS_DIR" ]]; then
    echo "no findings yet at $FINDINGS_DIR" >&2
    exit 1
  fi

  local arg="${1:-}"
  if [[ -z "$arg" ]]; then
    # mtime-sorted, most recent first; cap at 20 so it stays readable
    find "$FINDINGS_DIR" -name '*.log' -type f -print0 \
      | xargs -0 ls -t 2>/dev/null \
      | head -20
    return
  fi

  local file=""
  if [[ "$arg" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
    file="$FINDINGS_DIR/${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/${BASH_REMATCH[3]}.log"
  elif [[ "$arg" =~ ^[0-9]+$ ]]; then
    # Bare number — find any matching file. Multiple matches across orgs/repos
    # is ambiguous; fail with hints rather than guessing.
    local matches=()
    while IFS= read -r m; do matches+=("$m"); done < <(find "$FINDINGS_DIR" -name "$arg.log" -type f)
    if [[ ${#matches[@]} -eq 0 ]]; then
      echo "no findings log for PR #$arg" >&2; exit 1
    elif [[ ${#matches[@]} -gt 1 ]]; then
      echo "multiple matches for PR #$arg — pass the full URL to disambiguate:" >&2
      printf '  %s\n' "${matches[@]}" >&2
      exit 1
    fi
    file="${matches[0]}"
  else
    echo "expected a GitHub PR URL or bare number: $arg" >&2
    exit 2
  fi

  if [[ ! -f "$file" ]]; then
    echo "no findings log at $file" >&2; exit 1
  fi
  cat "$file"
}

# Remove a PR's held-ledger entry so the next tick re-reviews it. Accepts a
# full GitHub PR URL or a bare number (number must be unique across repos).
cmd_clear_hold() {
  local arg="${1:-}"
  if [[ -z "$arg" ]]; then
    echo "usage: pr-review-poller clear-hold <pr-url-or-number>" >&2; exit 2
  fi
  local LEDGER="$HOME/.local/state/pr-review-poller/held.json"
  if [[ ! -f "$LEDGER" ]]; then
    echo "no ledger at $LEDGER" >&2; exit 1
  fi

  local key=""
  if [[ "$arg" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
    key="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}#${BASH_REMATCH[3]}"
  elif [[ "$arg" =~ ^[0-9]+$ ]]; then
    local matches=()
    while IFS= read -r m; do matches+=("$m"); done \
      < <(jq -r --arg n "$arg" 'keys[] | select(endswith("#" + $n))' "$LEDGER")
    if [[ ${#matches[@]} -eq 0 ]]; then
      echo "no held entry for PR #$arg" >&2; exit 1
    elif [[ ${#matches[@]} -gt 1 ]]; then
      echo "multiple matches for PR #$arg — pass the full URL to disambiguate:" >&2
      printf '  %s\n' "${matches[@]}" >&2
      exit 1
    fi
    key="${matches[0]}"
  else
    echo "expected GitHub PR URL or bare number: $arg" >&2; exit 2
  fi

  local before
  before=$(jq -r --arg key "$key" '.[$key] // empty' "$LEDGER")
  if [[ -z "$before" ]]; then
    echo "no held entry for $key" >&2; exit 1
  fi

  local tmp; tmp=$(mktemp)
  jq --arg key "$key" 'del(.[$key])' "$LEDGER" > "$tmp" && mv "$tmp" "$LEDGER"
  echo "cleared $key"
}

SUB="${1:-status}"
[[ $# -gt 0 ]] && shift

case "$SUB" in
  status)     cmd_status     "$@" ;;
  start)      cmd_start      "$@" ;;
  stop)       cmd_stop       "$@" ;;
  run)        cmd_run        "$@" ;;
  logs)       cmd_logs       "$@" ;;
  findings)   cmd_findings   "$@" ;;
  clear-hold) cmd_clear_hold "$@" ;;
  config)     cmd_config     "$@" ;;
  help|-h|--help) cmd_help ;;
  *) echo "unknown subcommand: $SUB" >&2; cmd_help; exit 2 ;;
esac
