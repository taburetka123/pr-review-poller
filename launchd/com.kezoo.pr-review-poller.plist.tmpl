<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kezoo.pr-review-poller</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/kezoo/.local/bin/pr-review-poller</string>
        <string>run</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/kezoo/worktrees/.pr-review-poller-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/kezoo/worktrees/.pr-review-poller-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:/Users/kezoo/.local/bin</string>
    </dict>
</dict>
</plist>
