# Runtime config for pr-review-poller.
# install.sh writes this to ~/.config/pr-review-poller/config.env.
# Edit that file in place, or re-run install.sh with new flags.

# Commit-age gate: a PR is only reviewed once its newest commit is this old.
# Format: Nm (minutes) or Nh (hours). 0 disables the gate.
# Default 10m gives human reviewers a lead window and avoids reviewing mid-push.
MIN_COMMIT_AGE="10m"
